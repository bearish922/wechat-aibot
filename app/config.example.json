{
  "paths": {
    "npmGlobal": "可选；默认自动查找 npm 全局目录",
    "claude": "可选；默认从 PATH 自动查找 claude",
    "codex": "可选；默认从 PATH 自动查找 codex",
    "ragScript": "可选；默认使用 app/rag.py",
    "workDir": "可选；默认使用当前 Windows 用户目录"
  },
  "proxy": {
    "https": "",
    "claudeHttps": "",
    "codexHttps": "",
    "ragHttps": ""
  },
  "api": {
    "baseUrl": "",
    "apiKey": "",
    "model": "deepseek-v4-pro"
  },
  "models": {
    "claudeMain": "deepseek-v4-pro[1m]",
    "claudeFast": "deepseek-v4-flash[1m]",
    "claudeFallback": "deepseek-v4-flash[1m]",
    "codexMain": "gpt-5.5",
    "codexReasoningEffort": "high",
    "claudeContextMax": 1000000,
    "codexContextMax": 1000000,
    "scenelet": "deepseek-v4-pro[1m]"
  },
  "timeouts": {
    "aiMs": 600000
  },
  "sessions": {
    "profileNoSessionPersistence": false
  },
  "scene": {
    "mainVisibleContextTurns": 12,
    "sceneletVisibleContextTurns": 8,
    "proactiveVisibleContextTurns": 8,
    "sceneletBare": false
  },
  "vision": {
    "mode": "auto",
    "baseUrl": "https://api.siliconflow.cn/v1",
    "apiKey": "",
    "model": "Qwen/Qwen3-VL-32B-Instruct",
    "detail": "high",
    "timeoutMs": 180000
  },
  "voice": {
    "enabled": true,
    "whisperxPython": "optional path to the Python executable in a WhisperX virtual environment",
    "model": "large-v3",
    "language": "auto",
    "computeType": "default",
    "batchSize": 8,
    "sampleRate": 24000,
    "noAlign": true,
    "timeoutMs": 180000
  },
  "rag": {
    "enabled": true,
    "knowledgeDir": "data/knowledge",
    "storeDir": "data/rag_vector_store",
    "modelCacheDir": "data/.fastembed_cache",
    "collectionName": "bangdream_knowledge",
    "embedModel": "BAAI/bge-small-zh-v1.5",
    "topK": 3,
    "minScore": 0.48,
    "scoreMargin": 0.16,
    "timeoutMs": 45000,
    "rerankLimit": 256,
    "chunkMaxChars": 1600,
    "resultMaxChars": 1200,
    "batchSize": 32
  },
  "logs": {
    "retentionDays": 30
  }
}
